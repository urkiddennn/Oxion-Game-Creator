{
  "expo": {
    "name": "Oxion2d",
    "slug": "oxion-game-creator",
    "version": "1.15.9",
    "orientation": "landscape",
    "icon": "./assets/oxion.png",
    "backgroundColor": "#0F1115",
    "userInterfaceStyle": "dark",
    "jsEngine": "hermes",
    "androidStatusBar": {
      "hidden": true
    },
    "androidNavigationBar": {
      "visible": "sticky-immersive",
      "backgroundColor": "#1D1D3E"
    },
    "splash": {
      "image": "./assets/image.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/oxion.png",
        "backgroundColor": "#1D1D3E"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.richardbanguiz.oxion2d"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": false,
            "extraProguardRules": "-keep class com.facebook.react.turbomodule.** { *; }\n-keep class com.swmansion.reanimated.** { *; }\n-keep class com.facebook.yoga.** { *; }\n-keep class com.facebook.react.bridge.Systrace { *; }",
            "enableMinifyInReleaseBuilds": true
          }
        }
      ],
      "expo-sharing",
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "891ce5f9-42de-478b-b303-77b4f153453d"
      }
    },
    "owner": "urkiddenn"
  }
}
